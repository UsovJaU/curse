#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"
VENV_PYTHON="$VENV_DIR/bin/python"
VENV_PIP="$VENV_DIR/bin/pip"
REQUIREMENTS_FILE="$SCRIPT_DIR/requirements.txt"
LOCAL_VIRTUALENV_APP_DATA="$SCRIPT_DIR/.local/virtualenv-app-data"

create_venv() {
  mkdir -p "$LOCAL_VIRTUALENV_APP_DATA"

  if python3 -m venv "$VENV_DIR" >/dev/null 2>&1; then
    return
  fi

  if [ -x "/home/admen/.local/bin/virtualenv" ]; then
    VIRTUALENV_OVERRIDE_APP_DATA="$LOCAL_VIRTUALENV_APP_DATA" \
      /home/admen/.local/bin/virtualenv --clear "$VENV_DIR" >/dev/null
    return
  fi

  echo "Не удалось создать .venv: нет рабочего python3 -m venv и не найден virtualenv." >&2
  exit 1
}

ensure_venv() {
  if [ ! -x "$VENV_PYTHON" ] || [ ! -x "$VENV_PIP" ]; then
    echo "Создаю локальное окружение .venv..." >&2
    create_venv
  fi
}

ensure_dependencies() {
  if "$VENV_PYTHON" -c "import bs4, rapidfuzz, selenium" >/dev/null 2>&1; then
    return
  fi

  echo "Устанавливаю зависимости из requirements.txt..." >&2
  if ! "$VENV_PIP" install -r "$REQUIREMENTS_FILE"; then
    echo "Не удалось установить зависимости. Проверь доступ в интернет и повтори запуск." >&2
    exit 1
  fi
}

ensure_venv
ensure_dependencies

exec "$VENV_PYTHON" "$SCRIPT_DIR/main.py" "$@"
